# Logic Plan - Inn 'n Out Leave Pass System

## Pseudocode

START

DISPLAY Welcome Screen
DISPLAY Login / Register Option

IF user selects Register THEN
    INPUT name, email, password, role
    SAVE user information
    DISPLAY Registration Successful
END IF

IF user selects Login THEN
    INPUT email, password

    IF credentials are valid THEN
        IF role = Dormer THEN
            DISPLAY Dormer Dashboard
        ELSE IF role = Dorm Staff THEN
            DISPLAY Staff Dashboard
        END IF
    ELSE
        DISPLAY Invalid Login Message
        RETURN to Welcome Screen
    END IF
END IF

// Dormer Functions
IF user role = Dormer THEN
    DISPLAY list of submitted leave passes and their status

    IF dormer selects Submit Leave Pass THEN
        INPUT date of leave, time out, expected time in, reason
        SET status = "Pending"
        SAVE leave pass record
        DISPLAY Submission Successful
    END IF
END IF

// Staff Functions
IF user role = Dorm Staff THEN
    DISPLAY list of submitted leave passes with details

    FOR each pending leave pass
        DISPLAY leave pass details

        IF staff selects Approve THEN
            SET status = "Approved"
            UPDATE record
            DISPLAY Approval Successful
        ELSE IF staff selects Reject THEN
            SET status = "Rejected"
            INPUT rejection reason
            UPDATE record
            DISPLAY Rejection Message
        END IF
    END
